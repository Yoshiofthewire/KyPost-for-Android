<?xml version="1.0" encoding="utf-8"?>
<!-- Scrollable so the focused field (recipient/subject/body editor) can scroll above the
     keyboard instead of being clipped by it — composeRoot's bottom padding already grows by the
     IME inset (see AppTheme.applyTopInsetWithHeader), which only helps if there's a scroll
     container to reveal the extra space. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

<LinearLayout
    android:id="@+id/composeRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Details card: To/Cc/Bcc/Subject grouped as one form, thin dividers between rows
         (composeDetailsDivider1/2/3, themed to palette.line in ComposeActivity, same pattern as
         EmailDetailActivity's emailDivider). -->
    <LinearLayout
        android:id="@+id/composeDetailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <com.urlxl.mail.RecipientInputView
            android:id="@+id/composeToInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <View
            android:id="@+id/composeDetailsDivider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp" />

        <com.urlxl.mail.RecipientInputView
            android:id="@+id/composeCcInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <View
            android:id="@+id/composeDetailsDivider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp" />

        <com.urlxl.mail.RecipientInputView
            android:id="@+id/composeBccInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <View
            android:id="@+id/composeDetailsDivider3"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/compose_subject"
                android:textSize="12sp"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/composeSubjectField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Email subject" />

        </LinearLayout>

    </LinearLayout>

    <!-- Message card: icon-only formatting toolbar sits flush above the body editor (a hairline
         divider, not a gap, separates them) so the two read as one control. -->
    <LinearLayout
        android:id="@+id/composeMessageCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/composeBold"
                    style="@style/Widget.Llama.IconOnlyChip"
                    android:checkable="true"
                    app:chipIcon="@drawable/ic_bold"
                    android:contentDescription="@string/compose_format_bold" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/composeItalic"
                    style="@style/Widget.Llama.IconOnlyChip"
                    android:checkable="true"
                    app:chipIcon="@drawable/ic_italic"
                    android:contentDescription="@string/compose_format_italic" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/composeUnderline"
                    style="@style/Widget.Llama.IconOnlyChip"
                    android:checkable="true"
                    app:chipIcon="@drawable/ic_underline"
                    android:contentDescription="@string/compose_format_underline" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/composeLink"
                    style="@style/Widget.Llama.IconOnlyChip"
                    android:checkable="true"
                    app:chipIcon="@drawable/ic_link"
                    android:contentDescription="@string/compose_format_link" />

            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.chip.Chip
                android:id="@+id/composeAttachButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                app:chipIcon="@drawable/ic_attach"
                app:chipIconSize="18dp"
                android:text="@string/compose_attach"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <View
            android:id="@+id/composeMessageDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp" />

        <!-- Fixed height (not 0dp+weight): the RichHtmlEditorWebView forcibly overrides its own
             layoutParams.height to its content height via updateWebViewHeight, and NestedScrollView's
             fillViewport only re-stretches the content when the scroll view itself is measured with an
             EXACTLY spec. Under 0dp+layout_weight the child ends up collapsed to the empty editor's
             ~1-line content height, leaving the body blank. A concrete height keeps the box visible. -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:fillViewport="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.infomaniak.lib.richhtmleditor.RichHtmlEditorWebView
                    android:id="@+id/composeBodyEditor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- The editor has no native hint mechanism (it's a WebView); this mirrors it via
                     ComposeActivity toggling visibility off ComposeActivity's isEmptyFlow collector. -->
                <TextView
                    android:id="@+id/composeBodyPlaceholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/compose_body_hint"
                    android:textSize="16sp" />

            </FrameLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Attachments card: hidden entirely (not just its ChipGroup) when there are no attachments. -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/composeAttachmentsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:chipSpacingHorizontal="6dp" />

</LinearLayout>
</androidx.core.widget.NestedScrollView>
