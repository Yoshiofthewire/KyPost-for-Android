<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/composeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.urlxl.mail.RecipientInputView
        android:id="@+id/composeToInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <com.urlxl.mail.RecipientInputView
        android:id="@+id/composeCcInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <com.urlxl.mail.RecipientInputView
        android:id="@+id/composeBccInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/compose_subject"
            android:textSize="12sp"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/composeSubjectField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Email subject" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

    <com.google.android.material.chip.ChipGroup
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:chipSpacingHorizontal="6dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/composeBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_bold"
            android:textStyle="bold" />

        <com.google.android.material.chip.Chip
            android:id="@+id/composeItalic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_italic"
            android:textStyle="italic" />

        <com.google.android.material.chip.Chip
            android:id="@+id/composeUnderline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_underline" />

        <com.google.android.material.chip.Chip
            android:id="@+id/composeBulletList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_bullets" />

        <com.google.android.material.chip.Chip
            android:id="@+id/composeNumberList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_numbers" />

        <com.google.android.material.chip.Chip
            android:id="@+id/composeLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="@string/compose_format_link" />

    </com.google.android.material.chip.ChipGroup>

        <Button
            android:id="@+id/composeAttachButton"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/compose_attach" />

    </LinearLayout>

    <!-- Fixed height (not 0dp+weight): the RichHtmlEditorWebView forcibly overrides its own
         layoutParams.height to its content height via updateWebViewHeight, and NestedScrollView's
         fillViewport only re-stretches the content when the scroll view itself is measured with an
         EXACTLY spec. Under 0dp+layout_weight the child ends up collapsed to the empty editor's
         ~1-line content height, leaving the body blank. A concrete height keeps the box visible. -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginBottom="12dp"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_background">

            <com.infomaniak.lib.richhtmleditor.RichHtmlEditorWebView
                android:id="@+id/composeBodyEditor"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- The editor has no native hint mechanism (it's a WebView); this mirrors it via
                 ComposeActivity toggling visibility off ComposeActivity's isEmptyFlow collector. -->
            <TextView
                android:id="@+id/composeBodyPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:text="@string/compose_body_hint"
                android:textSize="16sp" />

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/composeAttachmentChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:chipSpacingHorizontal="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/composeCancelButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/composeSendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/compose_send" />

    </LinearLayout>

</LinearLayout>
